# Server
PORT=5000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here

# Database (Supabase Postgres)
DATABASE_URL=postgres://user:pass@host:5432/dbname
USE_POSTGRES=false

# Supabase Storage (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=public

# WhatsApp provider
WHATSAPP_PROVIDER=meta

# WhatsApp (Meta) - optional for live messaging
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=invoiceease-whatsapp-token
WHATSAPP_PUBLIC_NUMBER=

# Gupshup (used when WHATSAPP_PROVIDER=gupshup)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_NUMBER=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Resend (email)
RESEND_API_KEY=
