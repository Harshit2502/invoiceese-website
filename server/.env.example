# Environment Variables for InvoiceEase Server

# Port
PORT=5000
NODE_ENV=development

# Database Configuration
# Set USE_POSTGRES=true to use PostgreSQL instead of in-memory database
USE_POSTGRES=false
DB_USER=postgres
DB_HOST=localhost
DB_NAME=invoiceease
DB_PASSWORD=postgres
DB_PORT=5432

# JWT Secret
JWT_SECRET=invoiceease_secret_key_2026

# CORS - Client URL
CLIENT_URL=http://localhost:3000

# Base URL for PDF downloads
BASE_URL=http://localhost:5000

# Telegram Bot API Integration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# PDF Generation
PDF_GENERATOR_URL=https://api.example.com/pdf
