# Environment Variables for InvoiceEase Server

# Port
PORT=5000
NODE_ENV=development

# Database Configuration
# Set USE_POSTGRES=true to use PostgreSQL instead of in-memory database
USE_POSTGRES=false
DB_USER=postgres
DB_HOST=localhost
DB_NAME=invoiceease
DB_PASSWORD=postgres
DB_PORT=5432

# JWT Secret
JWT_SECRET=invoiceease_secret_key_2026

# CORS - Client URL
CLIENT_URL=http://localhost:3000

# Base URL for PDF downloads
BASE_URL=http://localhost:5000

# WhatsApp Integration (optional)
WHATSAPP_ACCESS_TOKEN=your_permanent_or_temporary_access_token
WHATSAPP_API_KEY=your_api_key_if_you_prefer_this_name
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=invoiceease-whatsapp-token
WHATSAPP_PUBLIC_NUMBER=919876543210

# PDF Generation
PDF_GENERATOR_URL=https://api.example.com/pdf
